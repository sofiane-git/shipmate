{
  "$schema": "https://raw.githubusercontent.com/sofiane-git/shipmate/main/schemas/shipmate-config.schema.json",
  "remote": "origin",
  "protectedBranch": "main",
  "primaryContract": "kit",
  "securityReview": "auto",
  "contracts": [
    {
      "name": "kit",
      "tag": "v{version}",
      "bumpFrom": "changelog",
      "locations": [
        { "file": "package.json", "json": ".version" },
        { "file": ".claude-plugin/plugin.json", "json": ".version" },
        { "file": ".claude-plugin/marketplace.json", "json": ".plugins[0].version" }
      ]
    }
  ]
}
